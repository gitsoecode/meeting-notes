node_modules/
dist/
*.tsbuildinfo
.DS_Store
.claude/
docs/private_plans/

# Build & test artifacts. Use `*` (not the directory itself) so individual
# entries below can be re-included — gitignore can't re-include a file
# whose parent directory is itself excluded.
packages/app/build/*
packages/app/playwright-report/
packages/app/test-results/
test-results/

# Tracked exceptions inside packages/app/build/ — committed source assets
# that the build pipeline reads from but doesn't generate. Without these
# exceptions the DMG packaging step would fail on a fresh checkout.
# `app-icon.iconset/` is intentionally NOT excepted: `build:icons`
# regenerates that directory from `assets/app-icon.png`, so its PNGs are
# build artifacts, not committed sources.
!packages/app/build/dmg-background.svg
!packages/app/build/dmg-background.png
!packages/app/build/dmg-background@2x.png

# electron-builder packaged output (.app, .zip, .dmg, blockmaps).
# Build artifacts only — regenerated by `npm run package:mac` /
# `package:mac:sign`. Distributed via GitHub Releases, not git.
packages/app/release/

# Bundled binaries (built from source by scripts, or dropped in locally
# out-of-band). Never checked into git. `.gitkeep` keeps the directory.
packages/app/resources/bin/*
!packages/app/resources/bin/.gitkeep

# Generated by scripts/write-build-flags.mjs at build time. Reflects
# package.json's `build.publish` config. Never edited by hand, never
# committed — fresh clones regenerate on first `npm run build:main`.
packages/app/main/build-flags.ts

.projects/cache
.projects/vault
.env
.env.local
