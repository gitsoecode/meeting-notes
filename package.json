{
  "name": "meeting-notes-monorepo",
  "version": "0.1.0",
  "description": "Local-first meeting recording and processing system",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/engine",
    "packages/cli",
    "packages/app"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:engine": "npm run build --workspace @meeting-notes/engine",
    "build:cli": "npm run build --workspace @meeting-notes/cli",
    "build:app": "npm run build --workspace @meeting-notes/app",
    "test": "npm run build && node --test packages/app/test/*.test.mjs",
    "dev:app": "npm run dev --workspace @meeting-notes/app",
    "start": "npm run start --workspace @meeting-notes/cli"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0"
  }
}
