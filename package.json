{
  "name": "meeting-notes",
  "version": "0.1.0",
  "description": "Local-first meeting recording and processing system with Obsidian integration",
  "type": "module",
  "bin": {
    "meeting-notes": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc && node -e \"require('fs').cpSync('src/defaults','dist/defaults',{recursive:true})\"",
    "dev": "tsc --watch",
    "start": "node dist/cli/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "private": true,
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@napi-rs/keyring": "^1.2.0",
    "commander": "^13.1.0",
    "gray-matter": "^4.0.3",
    "openai": "^6.33.0",
    "ulid": "^2.3.0",
    "yaml": "^2.7.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0"
  }
}
