{
  "name": "@meeting-notes/app",
  "version": "0.1.0",
  "description": "Meeting Notes desktop app",
  "private": true,
  "type": "module",
  "main": "dist/main/index.js",
  "scripts": {
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer && npm run build:assets",
    "build:assets": "npm run build:icons && node -e \"require('fs').cpSync('assets','dist/assets',{recursive:true});\"",
    "build:icons": "/usr/bin/python3 scripts/generate-icons.py",
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json && node -e \"require('fs').writeFileSync('dist/preload/package.json','{\\\"type\\\":\\\"commonjs\\\"}\\n')\"",
    "build:renderer": "vite build",
    "check:bundle": "node scripts/check-bundled-binaries.mjs",
    "package:mac": "npm run build && npm run check:bundle && electron-builder --mac --config.directories.output=release",
    "test": "npm run build --workspace @meeting-notes/engine && npm run build:main && node --test test/*.test.mjs",
    "test:e2e": "npm run build:renderer && playwright test",
    "dev": "npm run build:assets && concurrently -k -r \"npm run dev:main\" \"npm run dev:preload\" \"npm run dev:renderer\" \"npm run start:electron\"",
    "dev:main": "tsc -p tsconfig.main.json --watch --preserveWatchOutput",
    "dev:preload": "tsc -p tsconfig.preload.json --watch --preserveWatchOutput",
    "dev:renderer": "vite",
    "preview:renderer": "vite preview --host 127.0.0.1 --port 4173",
    "start:electron": "wait-on tcp:5173 dist/main/index.js dist/preload/index.js && electron .",
    "start": "electron ."
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.3.0",
    "@codemirror/theme-one-dark": "^6.1.2",
    "@codemirror/view": "^6.35.0",
    "@meeting-notes/engine": "*",
    "@milkdown/crepe": "^7.20.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@uiw/react-codemirror": "^4.23.7",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dompurify": "^3.2.3",
    "lucide-react": "^1.7.0",
    "markdown-it": "^14.1.0",
    "react": "^18.3.1",
    "react-day-picker": "^9.14.0",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.1.0",
    "electron": "^41.2.0",
    "electron-builder": "^25.0.0",
    "postcss": "^8.5.9",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.8.0",
    "vite": "^6.0.3",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.meeting-notes.app",
    "productName": "Meeting Notes",
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "icon": "assets/app-icon.icns",
      "category": "public.app-category.productivity"
    }
  }
}
