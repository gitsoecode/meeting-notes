                  "fontSize": "$--size-body",
                  "fontWeight": "500"
                },
                {
                  "type": "text",
                  "id": "w1fwd",
                  "name": "contextA",
                  "fill": "$--text-secondary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Yes. Keep a compact, always-visible context block in this file so design sessions do not need to reload AGENTS.md every time.",
