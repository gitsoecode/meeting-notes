                  "fontFamily": "Geist",
                  "fontSize": "$--size-body",
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "ziBkm",
                  "name": "identity",
                  "fill": "$--text-secondary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Product identity: Local-first desktop meeting workspace for solo power users. Obsidian is optional. Core value is editable markdown and customizable prompt-driven outputs.",
                  "lineHeight": 1.4,
                  "fontFamily": "Geist",
                  "fontSize": 12,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "6yEh4",
                  "name": "guardrail1",
                  "fill": "$--text-secondary",
                  "content": "Guardrail: Keep Electron sandbox enabled by default.",
                  "fontFamily": "Geist",
                  "fontSize": 12,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "T2uS3",
                  "name": "guardrail2",
                  "fill": "$--text-secondary",
                  "content": "Guardrail: Keep renderer filesystem access scoped; no arbitrary path APIs.",
                  "fontFamily": "Geist",
                  "fontSize": 12,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "GH7Hi",
                  "name": "guardrail3",
                  "fill": "$--text-secondary",
                  "content": "Guardrail: Validate run paths against configured runs root.",
                  "fontFamily": "Geist",
                  "fontSize": 12,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "Swr4M",
                  "name": "guardrail4",
                  "fill": "$--text-secondary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Direction: Prioritize first-session value for a solo user and preserve local-first desktop workflow.",
